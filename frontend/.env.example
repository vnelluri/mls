VITE_API_BASE_URL=http://localhost:8001
VITE_DEMO_MODE=true
VITE_ENTRA_TENANT_ID=
VITE_ENTRA_CLIENT_ID=
# Scope minting an access token for the backend API (its aud must match the
# backend's ENTRA_AUDIENCE/ENTRA_CLIENT_ID). Defaults to api://<client-id>/.default
# when unset; set explicitly if the API is a separate app registration.
VITE_ENTRA_API_SCOPE=
