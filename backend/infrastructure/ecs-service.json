{
  "cluster": "mlserv-cluster",
  "serviceName": "mlserv-backend",
  "taskDefinition": "mlserv-backend",
  "desiredCount": 2,
  "launchType": "FARGATE",
  "deploymentConfiguration": {
    "maximumPercent": 200,
    "minimumHealthyPercent": 100,
    "deploymentCircuitBreaker": {
      "enable": true,
      "rollback": true
    }
  },
  "networkConfiguration": {
    "awsvpcConfiguration": {
      "subnets": ["subnet-PRIVATE_A", "subnet-PRIVATE_B"],
      "securityGroups": ["sg-MLSERV_BACKEND"],
      "assignPublicIp": "DISABLED"
    }
  },
  "loadBalancers": [
    {
      "targetGroupArn": "arn:aws:elasticloadbalancing:us-east-1:ACCOUNT_ID:targetgroup/mlserv-backend/TARGET_GROUP_ID",
      "containerName": "mlserv-backend",
      "containerPort": 8000
    }
  ],
  "healthCheckGracePeriodSeconds": 30,
  "propagateTags": "SERVICE",
  "enableExecuteCommand": false
}
