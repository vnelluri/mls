{
  "family": "mlserv-backend",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "512",
  "memory": "1024",
  "executionRoleArn": "arn:aws:iam::ACCOUNT_ID:role/mlserv-ecs-execution-role",
  "taskRoleArn": "arn:aws:iam::ACCOUNT_ID:role/mlserv-backend-task-role",
  "containerDefinitions": [
    {
      "name": "mlserv-backend",
      "image": "ACCOUNT_ID.dkr.ecr.us-east-1.amazonaws.com/mlserv-backend:latest",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 8000,
          "protocol": "tcp"
        }
      ],
      "environment": [
        { "name": "AUTH_MODE", "value": "prod" },
        { "name": "AWS_REGION", "value": "us-east-1" },
        { "name": "DDB_ENDPOINT_URL", "value": "" },
        { "name": "EMR_MODE", "value": "mock" },
        { "name": "SNOWFLAKE_MODE", "value": "mock" },
        { "name": "CORS_ALLOWED_ORIGINS", "value": "https://mlserv.example.com" }
      ],
      "secrets": [
        { "name": "ENTRA_TENANT_ID", "valueFrom": "arn:aws:ssm:us-east-1:ACCOUNT_ID:parameter/mlserv/entra-tenant-id" },
        { "name": "ENTRA_CLIENT_ID", "valueFrom": "arn:aws:ssm:us-east-1:ACCOUNT_ID:parameter/mlserv/entra-client-id" },
        { "name": "ENTRA_JWKS_URL", "valueFrom": "arn:aws:ssm:us-east-1:ACCOUNT_ID:parameter/mlserv/entra-jwks-url" },
        { "name": "ENTRA_ISSUER", "valueFrom": "arn:aws:ssm:us-east-1:ACCOUNT_ID:parameter/mlserv/entra-issuer" },
        { "name": "ENTRA_AUDIENCE", "valueFrom": "arn:aws:ssm:us-east-1:ACCOUNT_ID:parameter/mlserv/entra-audience" }
      ],
      "healthCheck": {
        "command": ["CMD-SHELL", "python -c \"import urllib.request; urllib.request.urlopen('http://localhost:8000/health', timeout=5)\" || exit 1"],
        "interval": 30,
        "timeout": 10,
        "retries": 3,
        "startPeriod": 15
      },
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/mlserv-backend",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "backend"
        }
      }
    }
  ]
}
