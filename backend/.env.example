# ============================================================================
# Truist Model Serving (TMS) -- backend environment
#
# Copy this file to `.env` (scripts/dev.py does this automatically on first
# run). Env vars are read ONCE at process startup -- after editing `.env`,
# restart scripts/dev.py for changes to take effect.
#
# NOTE ON COMMENTS: never put an inline `# comment` after an EMPTY value
# (python-dotenv does not reliably strip it and the comment text becomes the
# literal value). Notes live on their own comment lines above each var.
# ============================================================================

# ---- Auth ------------------------------------------------------------------
# "dev" bypasses real JWT validation and injects the synthetic DEV_USER_*
# identity below. Set to "prod" to enable real Entra ID OIDC validation.
AUTH_MODE=dev

# Synthetic dev identity (only used when AUTH_MODE=dev).
# Role-switching for local testing:
#   LeadDataScientist -> full tenant-scoped write access (default, best for demos)
#   DataScientist     -> read-only within DEV_USER_TENANT_ID
#   PlatformAdmin     -> cross-tenant read-only; tenant_id is forced to null
# Seeded demo tenants: acme-capital, blue-harbor-bank
DEV_USER_ID=dev-user-1
DEV_USER_EMAIL=lead.ds@acme-demo.com
DEV_USER_NAME=Dev LeadDataScientist
DEV_USER_ROLE=LeadDataScientist
DEV_USER_TENANT_ID=acme-capital

# Convention-based group resolution (prod path only). Entra groups named
# "<prefix>-platform-<role>" / "<prefix>-<tenant>-<role>" resolve to a role
# and tenant by NAME, with no group-mapping table entry. Requires the groups
# claim to carry names: the tms-* groups are AD-synced and the app
# registration's optional claim must emit sAMAccountName.
GROUP_NAME_PREFIX=tms

# Entra ID (prod path only; leave as-is for local dev).
ENTRA_TENANT_ID=
ENTRA_CLIENT_ID=
ENTRA_JWKS_URL=
ENTRA_ISSUER=
ENTRA_AUDIENCE=

# ---- AWS / DynamoDB ----------------------------------------------------------
AWS_REGION=us-east-1
# Point at the local moto server for dev. Leave EMPTY (no value, no inline
# comment) in prod so boto3 talks to real AWS DynamoDB.
DDB_ENDPOINT_URL=http://127.0.0.1:5000
# Dummy credentials are fine for moto; real deployments use the task role.
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test

# ---- S3 artifacts bucket -----------------------------------------------------
# Shared bucket for model-artifact uploads (POST /models/artifacts); every
# tenant's uploads live under a "{tenant_id}/" prefix. In dev the same moto
# server that emulates DynamoDB serves S3 -- leave the endpoint EMPTY (no
# value, no inline comment) in prod for real S3 via the task role.
S3_ENDPOINT_URL=http://127.0.0.1:5000
S3_ARTIFACTS_BUCKET=mlserv-artifacts

# DynamoDB table names (rarely need changing).
TABLE_TENANTS=mlserv-tenants
TABLE_GROUP_MAPPINGS=mlserv-group-mappings
TABLE_PIPELINES=mlserv-pipelines
TABLE_JOBS=mlserv-jobs
TABLE_MODELS=mlserv-models
TABLE_MONITORING_SNAPSHOTS=mlserv-monitoring-snapshots
TABLE_AUDIT=mlserv-audit

# ---- Execution modes -----------------------------------------------------------
# EMR, Snowflake, and the DQ engine are PURE in-process mocks in "mock" mode --
# there is NO local emulator to start for any of them (moto does not
# meaningfully emulate emr-serverless, and no local Snowflake emulator
# exists). Only the DynamoDB moto server runs locally.
EMR_MODE=mock
# Platform-wide default Spark scoring entrypoint for EMR_MODE=real (see
# backend/emr/scoring_entrypoint.py; upload it to S3 and point this at it).
# Per-tenant override via the tenant's execution config.
EMR_ENTRYPOINT_S3_URI=
SNOWFLAKE_MODE=mock
# "real" computes data-quality/drift evidence from the run's actual parquet
# scoring output on S3 (requires pyarrow + S3 read access via the task role).
DQ_MODE=mock
# Fraction (0.0-1.0) of mock EMR runs that terminate FAILED, decided once at
# start time per run. 0.0 = every mock run succeeds.
EMR_MOCK_FAILURE_RATE=0.0

# ---- Snowflake connection (SNOWFLAKE_MODE=real only) -----------------------------
# The platform connects as a single SERVICE ACCOUNT -- users never connect to
# Snowflake and no user identity is forwarded to it. The role granted to this
# account bounds what any tenant pipeline can export; scope it tightly.
# The app refuses to start in real mode unless account, user, an auth method
# (private key or password), and the storage integration are all set.
# SNOWFLAKE_PRIVATE_KEY is PEM content (in AWS: SSM SecureString -> env).
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USER=
SNOWFLAKE_PRIVATE_KEY=
SNOWFLAKE_PRIVATE_KEY_PASSPHRASE=
SNOWFLAKE_PASSWORD=
SNOWFLAKE_ROLE=
SNOWFLAKE_STORAGE_INTEGRATION=

# ---- Data-quality engine (DQ_MODE=real only) --------------------------------------
# Byte budget when reading a run's scoring output from S3; files beyond it
# are skipped and the result is marked sampled. Default 536870912 (512 MiB).
DQ_MAX_BYTES=536870912

# ---- Monitoring thresholds (global defaults) ------------------------------------
PSI_WARN=0.10
PSI_FAIL=0.25
ERROR_RATE_WARN=0.05
ERROR_RATE_FAIL=0.15

# ---- Background refresh loop ------------------------------------------------------
JOB_REFRESH_INTERVAL_SECONDS=30
# Mock-mode step runtime: the data_quality_check timer and the mock
# data_pipeline query both complete after this many seconds. In real mode
# data_pipeline and execute_model are poll-driven and finish when Snowflake/
# EMR report a terminal state.
STEP_DURATION_SECONDS=30
# Hard per-step runtime ceiling: a step still running past this is failed and
# its EMR run cancelled (best-effort), so a stuck executor can never leave a
# job "running" forever. Default 21600 (6h).
STEP_TIMEOUT_SECONDS=21600

# ---- CORS ----------------------------------------------------------------------
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
