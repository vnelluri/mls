# ============================================================================
# ML Serving & Monitoring Platform -- backend environment
#
# Copy this file to `.env` (scripts/dev.py does this automatically on first
# run). Env vars are read ONCE at process startup -- after editing `.env`,
# restart scripts/dev.py for changes to take effect.
#
# NOTE ON COMMENTS: never put an inline `# comment` after an EMPTY value
# (python-dotenv does not reliably strip it and the comment text becomes the
# literal value). Notes live on their own comment lines above each var.
# ============================================================================

# ---- Auth ------------------------------------------------------------------
# "dev" bypasses real JWT validation and injects the synthetic DEV_USER_*
# identity below. Set to "prod" to enable real Entra ID OIDC validation.
AUTH_MODE=dev

# Synthetic dev identity (only used when AUTH_MODE=dev).
# Role-switching for local testing:
#   LeadDataScientist -> full tenant-scoped write access (default, best for demos)
#   DataScientist     -> read-only within DEV_USER_TENANT_ID
#   PlatformAdmin     -> cross-tenant read-only; tenant_id is forced to null
# Seeded demo tenants: acme-capital, blue-harbor-bank
DEV_USER_ID=dev-user-1
DEV_USER_EMAIL=lead.ds@acme-demo.com
DEV_USER_NAME=Dev LeadDataScientist
DEV_USER_ROLE=LeadDataScientist
DEV_USER_TENANT_ID=acme-capital

# Entra ID (prod path only; leave as-is for local dev).
ENTRA_TENANT_ID=
ENTRA_CLIENT_ID=
ENTRA_JWKS_URL=
ENTRA_ISSUER=
ENTRA_AUDIENCE=

# ---- AWS / DynamoDB ----------------------------------------------------------
AWS_REGION=us-east-1
# Point at the local moto server for dev. Leave EMPTY (no value, no inline
# comment) in prod so boto3 talks to real AWS DynamoDB.
DDB_ENDPOINT_URL=http://127.0.0.1:5000
# Dummy credentials are fine for moto; real deployments use the task role.
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test

# DynamoDB table names (rarely need changing).
TABLE_TENANTS=mlserv-tenants
TABLE_GROUP_MAPPINGS=mlserv-group-mappings
TABLE_PIPELINES=mlserv-pipelines
TABLE_JOBS=mlserv-jobs
TABLE_MODELS=mlserv-models
TABLE_MONITORING_SNAPSHOTS=mlserv-monitoring-snapshots
TABLE_AUDIT=mlserv-audit

# ---- Execution modes -----------------------------------------------------------
# EMR and Snowflake are PURE in-process mocks in "mock" mode -- there is NO
# local emulator to start for either (moto does not meaningfully emulate
# emr-serverless, and no local Snowflake emulator exists). Only the DynamoDB
# moto server runs locally.
EMR_MODE=mock
SNOWFLAKE_MODE=mock
# Fraction (0.0-1.0) of mock EMR runs that terminate FAILED, decided once at
# start time per run. 0.0 = every mock run succeeds.
EMR_MOCK_FAILURE_RATE=0.0

# ---- Monitoring thresholds (global defaults) ------------------------------------
PSI_WARN=0.10
PSI_FAIL=0.25
ERROR_RATE_WARN=0.05
ERROR_RATE_FAIL=0.15

# ---- Background refresh loop ------------------------------------------------------
JOB_REFRESH_INTERVAL_SECONDS=30
# Timer-driven steps (data_pipeline, data_quality_check) complete after this
# many seconds. execute_model steps are NOT timer-driven: they complete when
# the EMR execution service reports a terminal state (mock: ~10s).
STEP_DURATION_SECONDS=30
# Hard per-step runtime ceiling: a step still running past this is failed and
# its EMR run cancelled (best-effort), so a stuck executor can never leave a
# job "running" forever. Default 21600 (6h).
STEP_TIMEOUT_SECONDS=21600

# ---- CORS ----------------------------------------------------------------------
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
